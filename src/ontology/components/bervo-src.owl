        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000375 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000375">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>An instance where a prediction or test correctly identifies the absence of a condition or feature when it is actually absent. True negatives measure correct rejection of the null hypothesis in hypothesis testing.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000166"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>True negative</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000376 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000376">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>An instance where a prediction or test incorrectly fails to identify the presence of a condition or feature when it is actually present. False negatives represent missed detections and affect sensitivity metrics.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000167"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>False negative</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000377 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000377">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A statistical measure of the strength and direction of the linear relationship between two continuous variables. Correlation values range from -1 to +1 and are essential for understanding variable associations.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000168"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Correlation</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000378 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000378">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000377"/>
        <obo:IAO_0000115>A parametric correlation coefficient measuring the linear relationship between two continuous variables, assuming normal distribution. Pearson correlation is widely used for assessing strength of linear association in statistical analysis.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000169"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Pearson coefficient</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000227"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000379 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000379">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000377"/>
        <obo:IAO_0000115>A non-parametric rank-based correlation coefficient measuring monotonic relationships between two variables without assuming normality. Spearman correlation is robust to outliers and applicable to ordinal data.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000170"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Spearman coefficient</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000227"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000380 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000380">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000377"/>
        <obo:IAO_0000115>A non-parametric rank correlation coefficient measuring the strength of association between two variables based on concordant and discordant pairs. Kendall tau is distribution-free and suitable for small sample sizes.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000171"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Kendall tau coefficient</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000227"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000381 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000381">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A measure of association for ordinal variables that quantifies agreement between two ordinal rankings, accounting for tied observations. Gamma ranges from -1 to +1 and is less affected by table marginals.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000172"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Goodman and Kruskal&apos;s gamma</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000382 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000382">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A categorical variable or grouping variable that divides data into different levels or groups for analysis. Factors are essential for stratification, blocking, and categorical analysis in experimental design.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000175"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
