    <Class rdf:about="https://w3id.org/bervo/BERVO_8000389">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000238"/>
        <obo:IAO_0000115>A geographic region observing a uniform standard time, defined relative to Coordinated Universal Time (UTC). Time zones are essential for accurate temporal annotation in geographically distributed studies.</obo:IAO_0000115>
