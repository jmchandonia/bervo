        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000386 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000386">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Amplicon Sequence Variant, an exact biological sequence variant identified in high-throughput sequencing that represents true molecular entities. ASVs offer higher resolution than OTUs for microbial community characterization.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000185"/>
