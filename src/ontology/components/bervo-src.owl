        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000394"/>
        <obo:IAO_0000115>One of the major landmasses on Earth (Africa, Antarctica, Asia, Europe, North America, Oceania, South America). Continent designation provides high-level geographic classification for spatial analysis.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000213"/>
