        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000387 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000387">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The complementary DNA strand designated as plus (5&apos; to 3&apos;) or minus (3&apos; to 5&apos;), indicating directional orientation of genetic sequence. DNA strand designation is critical for sequence annotation and interpretation.</obo:IAO_0000115>
