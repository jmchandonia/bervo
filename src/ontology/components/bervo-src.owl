    <!-- https://w3id.org/bervo/BERVO_0001844 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_0001844">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_9000004"/>
        <obo:IAO_0000115>The rate at which ammonia molecules move through gaseous or aqueous media due to concentration gradients and molecular transport processes. This parameter is crucial for modeling ammonia emissions from fertilizers and nitrogen deposition processes in terrestrial and aquatic ecosystems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Ammonia diffusivity</rdfs:label>
