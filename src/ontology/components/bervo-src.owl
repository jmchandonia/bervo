        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000548 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000548">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000558"/>
        <obo:IAO_0000115>The generation or creation of biomass, offspring, or products by organisms or ecosystems, including net primary production, secondary production, and reproductive output. This attribute measures the rate of biological production processes.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
