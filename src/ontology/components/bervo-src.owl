        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000385 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000385">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Operational Taxonomic Unit, a grouping of sequences within a specified sequence similarity threshold used in microbial community analysis. OTUs approximate species-level groups in 16S rRNA gene sequencing.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000184"/>
        <oboInOwl:hasExactSynonym>OTU</oboInOwl:hasExactSynonym>
