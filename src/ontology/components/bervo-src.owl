    <!-- https://w3id.org/bervo/BERVO_8000309 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000309">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Descriptive information regarding mathematical operations, transformations, or analytical frameworks applied to data. This includes information about scaling approaches, normalization procedures, and mathematical conventions used in data processing and interpretation.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000018"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
