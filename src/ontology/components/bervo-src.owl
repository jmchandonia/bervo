        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000549 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000549">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The passage or transfer of energy, radiation, or substances through a medium, including light transmission through canopies or water transmission through soils. This attribute quantifies the fraction or rate of transmitted quantities through materials or systems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
