    <!-- https://w3id.org/bervo/BERVO_8000395 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000395">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000394"/>
        <obo:IAO_0000115>The angular distance north or south of the equator measured in degrees, minutes, and seconds (or decimal degrees). Latitude specifies the north-south coordinate in geographic positioning systems.</obo:IAO_0000115>
