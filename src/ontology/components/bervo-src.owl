        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000336 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000336">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000528"/>
        <obo:IAO_0000115>The unique identifier for protein domain families in the Pfam database representing evolutionarily related protein domains with conserved structures and functions. Pfam domain accessions enable identification of functional motifs and comparative protein evolution analysis.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000075"/>
        <oboInOwl:hasExactSynonym>pfam ID</oboInOwl:hasExactSynonym>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Pfam domain accession</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000337 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000337">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The increase in organism biomass, cell number, or population size per unit time, quantifying the speed of biological growth under specific conditions. Growth rate measurements are fundamental for assessing organism fitness, evaluating culture performance, and determining population dynamics in microbial and ecological studies.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000079"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Growth rate</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000095"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000338 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000338">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The time interval required for a population to double in size during exponential growth phase. Doubling time is a key parameter characterizing organism growth rate and is essential for assessing growth kinetics and comparing growth performance under different conditions.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000080"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Doubling time</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000339 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000339">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The elapsed time interval from introduction of organisms into culture media until the time of sampling or measurement. Time since inoculation is essential for relating growth measurements to the exponential, stationary, or death phases of microbial growth curves.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000081"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Time since inoculation</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000340 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000340">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The hierarchical rank within the Linnaean classification system (kingdom, phylum, class, order, family, genus, species) at which an organism is identified. Taxonomic level specification determines the resolution and precision of biological classification and affects interpretation of biodiversity and community composition.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000090"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Taxonomic level</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000341 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000341">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The observable phenotypic or functional consequence resulting from genetic modification, strain substitution, or evolutionary changes in a microbial population. Strain change effects provide insights into genotype-phenotype relationships and the adaptive significance of genetic variations in experimental and environmental contexts.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000092"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Strain change effect</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="https://w3id.org/bervo/BERVO_8000032"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000342 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000342">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A physical specimen collected from natural environments such as soils, waters, sediments, or organisms, representing a specific location and time. Environmental samples are fundamental for characterizing ecosystem conditions, tracking environmental changes, and conducting field-based biogeochemical research.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000100"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Environmental sample</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000343 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000343">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A measurable property of the physical, chemical, or biological environment such as temperature, pH, moisture content, or nutrient concentration. Environmental parameters characterize the conditions influencing organism function and biogeochemical processes in natural and managed ecosystems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000103"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Environmental parameter</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000344 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000344">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The mechanisms and processes through which biological communities develop and stabilize over time, including colonization, competition, facilitation, and stochastic processes. Community assembly processes determine ecosystem structure, functional redundancy, and resilience to environmental disturbances.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000105"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Community assembly process</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000345 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000345">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The categorization of sequencing reads based on their origin (single-end vs. paired-end) and structural characteristics (full-length, 16S, metagenome, transcriptome). Read type specification is essential for appropriate bioinformatic processing and interpretation of molecular data.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000112"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Read type</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000346 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000346">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The platform and methodology used for DNA or RNA sequencing, including next-generation sequencing (Illumina, PacBio, Nanopore) and traditional approaches. Sequencing technology selection critically affects read quality, read length, throughput, and cost of molecular analyses.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000116"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Sequencing technology</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000347 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000347">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A quantitative or qualitative determination of a physical, chemical, or biological property using established protocols and calibrated instruments. Measurement accuracy and precision are fundamental to data quality and scientific reproducibility across all empirical research.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000120"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Measurement</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000348 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000348">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A measure of a material&apos;s ability to conduct electrical current, primarily determined by dissolved ion concentration and mobility. Conductivity is an important indicator of water quality, salinity, and total dissolved solids in aquatic and terrestrial systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000124"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Conductivity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000349 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000349">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The electron activity or oxidation-reduction potential of a solution, measured in millivolts, indicating the tendency of substances to be oxidized or reduced. Redox potential controls the solubility and bioavailability of elements and drives major biogeochemical transformations in environmental systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000125"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Redox potential</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000350 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000350">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The physical dimension or scale of an object, organism, or particle measured in linear units (length, width, height, diameter). Size measurements are fundamental for characterizing physical properties, particle distributions, and organism morphology in biogeochemical studies.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000128"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Size</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000351 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000351">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The signal strength or fluorescence intensity resulting from molecular hybridization between labeled probes and complementary sequences. Hybridization intensity measurements are fundamental for microarray analysis, enabling quantification of nucleic acid abundance and identification of genomic variations.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000130"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Hybridization intensity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000352 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000352">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The quantitative measure of gene or protein abundance in a cell, tissue, or organism reflecting the activity of genetic regulation. Expression level measurements are essential for understanding functional gene activity, metabolic capacity, and stress responses in biogeochemical contexts.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000131"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
