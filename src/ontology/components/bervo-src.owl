        <bervo:BERVO_measurement_of rdf:resource="https://w3id.org/bervo/BERVO_8000024"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_0001841 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_0001841">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_9000004"/>
        <obo:IAO_0000115>The rate at which oxygen molecules move through gaseous or aqueous media due to concentration gradients and molecular transport processes. This parameter is fundamental for modeling soil aeration dynamics and aerobic respiration processes in terrestrial and aquatic ecosystems.</obo:IAO_0000115>
