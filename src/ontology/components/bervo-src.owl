        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>g d-2</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000007"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
