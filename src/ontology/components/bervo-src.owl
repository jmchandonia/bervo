        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000384 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000384">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A linear combination of original variables that captures maximum variance in multivariate data with minimal dimensionality. Principal components are orthogonal and ordered by descending variance.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000178"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
