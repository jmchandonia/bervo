        <bervo:BERVO_has_unit>oC</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="https://w3id.org/bervo/BERVO_8000050"/>
