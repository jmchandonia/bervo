    <!-- https://w3id.org/bervo/BERVO_8000531 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000531">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The action or process of flowing into and/or out of a substance or environment.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Manual (JHC, Dec 22 2025)</rdfs:comment>
        <rdfs:label>Flux</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
