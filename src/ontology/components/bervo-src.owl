    <!-- https://w3id.org/bervo/BERVO_8000331 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000331">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A functional unit of heredity encoding protein sequences or regulatory RNAs that govern organism phenotype and metabolic capability. Gene designation enables linking of genomic information with functional traits and ecological characteristics in biogeochemical and evolutionary research.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000059"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
