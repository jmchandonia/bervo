        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000133"/>
        <bervo:BERVO_Context rdf:resource="https://w3id.org/bervo/BERVO_8000133"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
