        <bervo:BERVO_has_unit>g d-2 h-1</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000171"/>
        <bervo:BERVO_measurement_of rdf:resource="https://w3id.org/bervo/BERVO_8000188"/>
    </Class>
    


