    <!-- https://w3id.org/bervo/BERVO_8000532 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000532">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The instantaneous or present-time value of a quantity, representing the state at the current computational time step or measurement instance. This temporal qualifier distinguishes real-time measurements from historical or predicted values in dynamic environmental models.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Current</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000533 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000533">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The value of a quantity from the preceding time step or measurement period, used for tracking temporal changes and calculating rates of change. This temporal qualifier enables analysis of how variables evolve over time in dynamic environmental simulations.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Previous</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000533"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000534 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000534">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The accumulated or aggregated value of a quantity over a defined time period, representing the running total from a starting point to the present. This temporal qualifier is essential for quantifying total inputs, outputs, or transformations in ecosystem budgets and biogeochemical cycles.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Cumulative</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000254"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000535 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000535">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A mathematical transformation where values are expressed on a logarithmic scale, often used to compress large ranges of values or represent multiplicative relationships. This qualifier indicates that the variable has been log-transformed for analysis or presentation.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Logarithmic</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000536 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000536">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Relating to water movement, distribution, and properties in environmental systems including precipitation, runoff, infiltration, and groundwater flow. This qualifier indicates that a variable pertains specifically to water cycle processes and hydrological phenomena.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Hydrological</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000537 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000537">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A qualifier indicating that the quantity represents a negative value or direction, often used to distinguish loss or removal processes from gain or addition processes. This directional qualifier is important for understanding bidirectional fluxes and net balances in biogeochemical systems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Negative</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000538 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000538">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The release or discharge of substances, energy, or radiation from a source into the environment. This attribute quantifies outputs from biological, chemical, or physical processes including greenhouse gas emissions, pollutant releases, and radiation outputs in environmental systems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Emission</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000538"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000539 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000539">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000558"/>
        <obo:IAO_0000115>The metabolic process by which organisms convert organic compounds into energy while releasing carbon dioxide. This attribute measures the rate or amount of respiratory activity in plants, animals, and microorganisms, representing a fundamental component of ecosystem carbon cycling.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Respiration</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000539"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000540 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000540">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The opposition to flow, movement, or change in a system, including electrical resistance, hydraulic resistance, or ecological resistance to disturbance. This attribute quantifies how strongly a system impedes processes or maintains stability against perturbations.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Resistance</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000540"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000541 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000541">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The decrease or removal of mass, energy, or substances from a system through various pathways including leaching, volatilization, runoff, or consumption. This attribute quantifies outputs and depletions in ecosystem mass balance and biogeochemical cycling.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Loss</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000542 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000542">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000558"/>
        <obo:IAO_0000115>The biological breakdown of organic compounds into inorganic forms, converting organic nitrogen to ammonium, organic phosphorus to phosphate, and organic carbon to carbon dioxide. This attribute measures the rate of nutrient transformation from organic to plant-available inorganic forms in soils and aquatic systems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Mineralization</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000542"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000062"/>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000091"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000543 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000543">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The capacity of a material to absorb radiation, heat, or substances, expressed as the fraction of incident energy or material absorbed. This attribute quantifies absorption efficiency in processes including solar radiation interception by vegetation and nutrient uptake by organisms.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Absorptivity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000543"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000544 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000544">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The maximum amount or extent that a system can hold, process, or produce, including water holding capacity, nutrient retention capacity, or productive capacity. This attribute quantifies the limits and potentials of environmental and biological systems.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Capacity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000544"/>
