        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>MgC m-3</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000151"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


