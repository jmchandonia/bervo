        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000547 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000547">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000558"/>
        <obo:IAO_0000115>The transfer of dead plant material including leaves, branches, flowers, and fruits from living vegetation to the soil surface. This attribute quantifies the rate of organic matter and nutrient return from vegetation to soil through senescence and shedding.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Litterfall</rdfs:label>
