        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000383 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000383">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The correlation or weight indicating the contribution of an observed variable to a latent factor in factor analysis. Factor loadings quantify the relationship between variables and underlying factors.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000176"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
