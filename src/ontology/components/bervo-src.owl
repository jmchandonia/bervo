    <!-- https://w3id.org/bervo/BERVO_8000393 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000393">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A coordinated series of observations, measurements, or activities conducted over a defined temporal or spatial scope. Campaigns organize related data collection efforts for a specific research objective.</obo:IAO_0000115>
