        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000550 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000550">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The rate of water movement or transfer through a system, including evapotranspiration flux, infiltration flux, or lateral water flow. This attribute quantifies water transport processes fundamental to hydrological cycling and ecosystem water balance.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
