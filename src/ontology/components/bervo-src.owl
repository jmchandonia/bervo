    <!-- https://w3id.org/bervo/BERVO_8000558 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000558">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A process carried out by living organisms or biological systems that transforms matter, energy, or information over time. This concept provides a general parent for process-oriented BERVO terms such as respiration, mineralization, production, and other organism- or ecosystem-driven activities.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <rdfs:comment> Mar 26 2026)</rdfs:comment>
