        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000332 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000332">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000528"/>
        <obo:IAO_0000115>The GenBank identifier (GI number) serving as a unique accession reference for specific gene sequences in public databases. GI numbers enable unambiguous linking of experimental data to specific genetic sequences and facilitate bioinformatic analyses.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000061"/>
        <oboInOwl:hasExactSynonym>genbank ID</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>genbank accession</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>gene ID</oboInOwl:hasExactSynonym>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Gene GI</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000333 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000333">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A functional macromolecule composed of amino acids that catalyzes reactions, provides structural support, and regulates cellular processes. Protein characterization and quantification are fundamental for understanding enzyme activity, metabolic capacity, and biochemical function in organisms and environmental systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000066"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Protein</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000334 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000334">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A functional classification system from the KEGG database that groups genes and proteins involved in specific metabolic or signaling pathways. KEGG subsystem annotations enable systematic analysis of organism metabolic capabilities and prediction of functional roles in biogeochemical cycling.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000068"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>KEGG subsystem</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000335 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000335">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A functional classification system from The Institute for Genomic Research (TIGR) that assigns functional roles to proteins based on sequence homology and structural similarities. TIGR roles enable systematic functional annotation and comparative metabolic analysis across microbial genomes.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000069"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
