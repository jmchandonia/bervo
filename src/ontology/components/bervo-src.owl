    <!-- https://w3id.org/bervo/BERVO_8000310 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000310">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A descriptive specification indicating the reference state, baseline, or comparative standard against which a measurement is expressed. This provides essential context for interpreting values that represent changes, differences, or ratios relative to a defined reference condition.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000020"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Relative</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000311 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000311">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Information describing the chemical environment, reaction conditions, molecular interactions, or the role of specific molecules within chemical processes or experimental systems. Chemical context includes reaction type, substrate role, product formation, and chemical mechanistic information.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000026"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Chemical context</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000312 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000312">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A specification of chemical identity when molecular composition or structure varies as a dimension in experiments or datasets. This concept enables tracking of chemical diversity in reaction systems, metabolic pathways, or multi-component analyses where different molecules are analyzed or compared.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000027"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Molecule</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000313 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000313">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A description of a chemical or biochemical transformation specifying reactants, products, reaction conditions, and mechanistic information. Reaction descriptions enable understanding of stoichiometry, energy requirements, and biological or environmental significance of chemical processes.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000028"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Reaction</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000314 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000314">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A categorical description of the physical surface on which interactions, reactions, or adsorption processes occur, such as mineral surfaces, organic matter, biofilm matrices, or interface boundaries. Surface type critically influences reaction rates, mass transport, and binding affinities in environmental and biological systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000029"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Surface type</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000315 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000315">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A specification of the material composition and surface properties of beads used in laboratory experiments such as soil homogenization, grinding, or chemical extraction procedures. Bead type selection affects contamination risk, extraction efficiency, and final sample composition in geochemical and biogeochemical analyses.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000030"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Bead type</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000316 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000316">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The physical diameter or volume specifications of beads employed in soil or tissue homogenization and chemical extraction procedures. Bead size directly influences grinding efficiency, shear forces, and the uniformity of particle size distribution in processed samples.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000031"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Bead size</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000317 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000317">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The change in enthalpy (ΔH) representing the heat energy absorbed or released during a chemical reaction at constant pressure. Delta-H is fundamental for assessing reaction spontaneity, thermodynamic feasibility, and energy requirements in biogeochemical processes and environmental chemistry applications.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000034"/>
        <oboInOwl:hasExactSynonym>deltaH</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>ΔH</oboInOwl:hasExactSynonym>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Delta-H</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000318 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000318">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The catalytic activity of an enzyme normalized to protein mass, expressed as units of product formed per unit time per unit protein. Specific activity quantifies enzyme efficiency and purity, enabling standardization of enzyme measurements and comparison of catalytic performance across different protein preparations.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000035"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Specific activity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000127"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000319 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000319">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000241"/>
        <obo:IAO_0000115>The distance between successive peaks or troughs of electromagnetic radiation, determining the energy and spectral characteristics of light. Wavelength specifications are critical for spectroscopy, photometry, and light-dependent processes such as photosynthesis and phototaxis in environmental and biological studies.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000036"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Wavelength</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000320 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000320">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A descriptor of the physical and chemical status of matter including phase (solid, liquid, gas), solubility state, sorption status, or location within environmental compartments. This concept specifies whether substances are dissolved, suspended, sorbed, or present in particular environmental matrices, affecting their bioavailability and environmental fate.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000037"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Physicochemical state</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000321 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000321">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The minimum concentration, mass, or signal intensity that can be reliably distinguished from background noise by an analytical instrument or method. Detection limits define the lower boundary of quantitative measurement ranges and are critical for data quality assessment and comparison of analytical capabilities.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000038"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Detection limit</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000322 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000322">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>Information describing the biological setting, organismal status, population characteristics, or ecological relationships relevant to a measurement or observation. Biological context includes organism identity, life stage, metabolic state, and ecological role, essential for interpreting biological and biogeochemical data.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000039"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Biological context</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000323 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000323">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A genetically distinct population of microorganisms identified by strain designation, culture collection number, or isolate designation. Microbial strain specification is essential for reproducibility of microbiological research and enables tracking of specific phenotypic or genotypic characteristics across experiments.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000042"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Microbial strain</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="https://w3id.org/bervo/BERVO_8000091"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000324 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000324">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The taxonomic classification of an organism at various hierarchical levels including species, genus, family, or higher ranks. Taxon designation enables biological identification, comparative analysis, and linking of experimental data to phylogenetic and ecological frameworks.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000045"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Taxon</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000325 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000325">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The nutrient-containing liquid, semi-solid, or solid preparation used to culture microorganisms or cells. Media selection influences organism growth, metabolic activity, and community structure in laboratory experiments and is critical for replicability and standardization of microbial research.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000048"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Media</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000326 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000326">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000325"/>
        <obo:IAO_0000115>A specification of the chemical constituents, nutrient elements, and trace components comprising growth media. Media composition documentation enables reproducibility and understanding of how nutrient availability and chemical environment influence organism growth and metabolism.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000050"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Media composition</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000327 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000327">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000326"/>
        <obo:IAO_0000115>Amendments or supplements added to culture media such as vitamins, growth factors, chelating agents, or specialized compounds. Media additions enable targeted modification of growth conditions and selective cultivation of organisms with specific nutritional or physiological requirements.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000052"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Media addition</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000328 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000328">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The compound or element used as a nitrogen supply for microbial or plant growth, including inorganic forms (nitrate, ammonium) and organic forms (amino acids, proteins). Nitrogen source type influences microbial community composition and metabolic pathways in biogeochemical cycling.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000056"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Nitrogen source</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="https://w3id.org/bervo/BERVO_8000167"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000329 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000329">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The reduced chemical compound that serves as the primary energy source for microbial oxidative metabolism and growth, such as hydrogen, sulfide, iron(II), or organic matter. Electron donor identity determines the thermodynamic driving force and metabolic type of microorganisms in environmental systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000057"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Electron donor</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000330 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000330">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The oxidized chemical species that serves as the terminal electron acceptor in microbial respiration, including oxygen, nitrate, sulfate, iron(III), and other inorganic compounds. Electron acceptor availability determines the thermodynamic favorability and type of respiration (aerobic, anaerobic) in biogeochemical systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000058"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Electron acceptor</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
