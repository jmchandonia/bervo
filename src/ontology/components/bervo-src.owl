        <bervo:BERVO_Context rdf:resource="https://w3id.org/bervo/BERVO_8000131"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000280"/>
        <bervo:BERVO_has_unit>ppmv</bervo:BERVO_has_unit>
