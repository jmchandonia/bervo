        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000254"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000265"/>
        <bervo:BERVO_has_unit>m3 H2O d-2</bervo:BERVO_has_unit>
