        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000546 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000546">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000558"/>
        <obo:IAO_0000115>The rate at which energy is converted to organic matter through photosynthesis by primary producers, representing the fundamental energy input to ecosystems. This attribute measures the gross or net production of biomass by autotrophic organisms.</obo:IAO_0000115>
        <rdfs:comment>Definition source - Claude Sonnet 4 through GitHub Copilot in VSCode (Jan 8 2026)</rdfs:comment>
        <rdfs:label>Primary productivity</rdfs:label>
