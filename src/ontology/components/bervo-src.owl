        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000559 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000559">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000255"/>
        <obo:IAO_0000115>The horizontal direction of a line, view, or vector measured clockwise from a reference direction, typically geographic north. Azimuth describes orientation or bearing within a horizontal plane and is commonly reported in degrees.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="Class"/>
        <oboInOwl:hasExactSynonym>bearing</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>compass azimuth</oboInOwl:hasExactSynonym>
        <rdfs:comment> May 4 2026)</rdfs:comment>
        <rdfs:comment>Definition source - Manual (JMC</rdfs:comment>
        <rdfs:label>Azimuth</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="degree"/>
        <bervo:BERVO_has_value_type rdf:resource="NA"/>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000560 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000560">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000255"/>
        <obo:IAO_0000115>The angular extent of the cone or region over which an instrument accepts incoming radiation or observes a scene. Field of view angle describes aperture width rather than the direction the instrument is aimed and is commonly reported in degrees.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="Class"/>
        <oboInOwl:hasExactSynonym>FOV</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>field of view</oboInOwl:hasExactSynonym>
        <rdfs:comment> May 4 2026)</rdfs:comment>
        <rdfs:comment>Definition source - Manual (JMC</rdfs:comment>
        <rdfs:label>Field of view angle</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="degree"/>
        <bervo:BERVO_has_value_type rdf:resource="NA"/>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000561 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000561">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A dimensionless correction factor applied during optical canopy or leaf area index processing to adjust gap fraction or transmittance estimates for radiation scattered into the sensor field of view. This factor represents a data-processing correction rather than the physical scattering process itself.</obo:IAO_0000115>
        <rdfs:comment> May 4 2026)</rdfs:comment>
        <rdfs:comment>Definition source - Manual (JMC</rdfs:comment>
        <rdfs:label>Scattering correction factor</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>dimensionless</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000562 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000562">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A dimensionless index describing the apparent non-random spatial aggregation of foliage inferred from canopy optical measurements, commonly calculated as the ratio of effective leaf area index to clumping-corrected or true leaf area index. Values below 1 indicate more clumped foliage relative to a random distribution.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="Class"/>
        <oboInOwl:hasExactSynonym>ACF</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>apparent clumping index</oboInOwl:hasExactSynonym>
        <rdfs:comment> May 4 2026)</rdfs:comment>
        <rdfs:comment>Definition source - Manual (JMC</rdfs:comment>
        <rdfs:label>Apparent clumping factor</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="dimensionless"/>
        <bervo:BERVO_has_value_type rdf:resource="https://w3id.org/bervo/BERVO_8000117"/>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


