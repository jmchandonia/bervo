    <!-- https://w3id.org/bervo/BERVO_0001840 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_0001840">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_9000004"/>
        <obo:IAO_0000115>The rate at which methane molecules move through gaseous or aqueous media due to concentration gradients and molecular transport processes. This parameter is crucial for modeling methane production and emissions from terrestrial and aquatic ecosystems and understanding greenhouse gas dynamics in Earth system models.</obo:IAO_0000115>
