    <!-- https://w3id.org/bervo/BERVO_8000353 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000353">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The catalytic efficiency of an enzyme measured as the rate of substrate conversion per unit enzyme or per unit time. Enzyme activity measurements quantify metabolic function and are critical for assessing organism capability to perform specific biogeochemical transformations.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000132"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Enzyme activity</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="https://w3id.org/bervo/BERVO_8000127"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000354 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000354">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A quantitative measure of organism survival, reproduction, or competitiveness relative to wild-type or reference strains. Fitness scores enable assessment of genetic variants&apos; ecological and physiological consequences in laboratory and environmental contexts.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000137"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Fitness score</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000355 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000355">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A quantitative measure of synergistic or antagonistic effects between two genetic mutations or perturbations beyond their individual contributions. Genetic interaction scores reveal epistatic relationships and functional interdependencies between genes in complex biological systems.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000138"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Genetic interaction score</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000356 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000356">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The proportional relationship between reactants or products in chemical or biochemical reactions based on molecular formulas. Stoichiometric ratios are fundamental for calculating reaction yields, energy requirements, and elemental cycling rates in biogeochemical models.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000139"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Stoichiometric ratio</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000357 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000357">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A data format or classification system with two mutually exclusive states or categories (yes/no, present/absent, true/false). Binary representations enable efficient storage and analysis of presence-absence data and dichotomous properties in large datasets.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000141"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Binary</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000358 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000358">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A Boolean property indicating the occurrence or detection of a substance, organism, genetic element, or phenotype in a sample or environment. Presence data enables community composition analysis and tracking of specific organisms or traits across samples.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000144"/>
        <oboInOwl:hasExactSynonym>extant</oboInOwl:hasExactSynonym>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Presence</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000359 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000359">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A Boolean property indicating whether a gene, protein, or metabolic function is required for organism survival under specified conditions. Essentiality assessments reveal functionally critical genes and identify metabolic bottlenecks in biotechnology and evolutionary studies.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000145"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Essentiality</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000360 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000360">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A numerical summary or descriptive measure derived from data that characterizes properties of the sample or population. Statistics are essential tools for data analysis, hypothesis testing, and inference in empirical scientific research.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000146"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Statistic</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000361 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000361">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The arithmetic result of subtracting one value from another, quantifying the magnitude of change or contrast between two measurements. Differences are fundamental for assessing treatment effects, temporal trends, and comparative analysis across conditions.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000148"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Difference</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000362 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000362">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A measure of data dispersion quantifying how individual values deviate from the mean, expressed in the same units as the original data. Standard deviation is essential for assessing measurement variability and comparing precision across different datasets and methods.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000149"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Standard deviation</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000362"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000363 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000363">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The standard deviation of the sampling distribution of a statistic, quantifying uncertainty in sample-based estimates. Standard error is critical for confidence intervals and hypothesis testing in statistical inference.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000150"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Standard error</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="https://w3id.org/bervo/BERVO_8000363"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000364 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000364">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The central value in a distribution that divides the data into equal halves when ranked in order. The median is a robust measure of central tendency less affected by outliers than the mean.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000153"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Median</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000365 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000365">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The logarithmic transformation of the ratio between two values, widely used for data visualization and statistical analysis of fold-changes and relative abundances. Log ratios stabilize variance and linearize exponential relationships in biological data.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000155"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Log ratio</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000366 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000366">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The probability of observing test statistics as extreme as or more extreme than the observed value under the null hypothesis. P-values are fundamental for statistical hypothesis testing and determining significance of research findings.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000156"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>P value</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000367 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000367">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>A statistical test value derived from t-tests used to compare means between groups and assess significance of differences. T-scores quantify the ratio of difference to variability and are fundamental for parametric hypothesis testing.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000157"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>T score</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000368 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000368">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>The number of occurrences or repetitions of an event or observation within a defined interval or dataset. Frequency is fundamental for describing the distribution of categorical and quantitative variables in statistical analysis.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000158"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Frequency</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000369 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000369">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A ratio measure comparing the observed frequency or concentration of a feature relative to its expected or baseline value. Fold enrichment quantifies whether an outcome is more or less common than would be expected by chance.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000159"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Fold enrichment</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000370 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000370">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>A measure of certainty or trust in an estimate, prediction, or result, often expressed as a confidence level or confidence interval. Confidence reflects the degree of reliability in statistical inference and data interpretation.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000160"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Confidence</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000371 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000371">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The proportion of predicted positive cases that are actually true positive, measuring the exactness and reliability of predictions. High precision indicates low false positive rate in classification tasks.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000162"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Precision</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000372 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000372">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000244"/>
        <obo:IAO_0000115>The proportion of actual positive cases that are correctly identified by a prediction model, also known as sensitivity or true positive rate. High recall indicates comprehensive detection of true positive cases.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000163"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000373 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000373">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>An instance where a prediction or test correctly identifies the presence of a condition or feature when it is actually present. True positives are a key metric for evaluating classifier performance and diagnostic accuracy.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000164"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
        <rdfs:label>True positive</rdfs:label>
        <bervo:BERVO_Attribute rdf:resource="NA"/>
        <bervo:BERVO_Context rdf:resource="NA"/>
        <bervo:BERVO_Qualifier rdf:resource="NA"/>
        <bervo:BERVO_has_unit>NA</bervo:BERVO_has_unit>
        <bervo:BERVO_measured_in rdf:resource="NA"/>
        <bervo:BERVO_measurement_of rdf:resource="NA"/>
    </Class>
    


    <!-- https://w3id.org/bervo/BERVO_8000374 -->

    <Class rdf:about="https://w3id.org/bervo/BERVO_8000374">
        <rdfs:subClassOf rdf:resource="https://w3id.org/bervo/BERVO_8000232"/>
        <obo:IAO_0000115>An instance where a prediction or test incorrectly identifies the presence of a condition or feature when it is actually absent. False positives represent incorrect positive predictions and affect specificity metrics.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:resource="COMO:0000165"/>
        <rdfs:comment>Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)</rdfs:comment>
