property_value: bervo:BERVO_Qualifier http://www.w3.org/2002/07/NA

[Term]
id: bervo:BERVO_8000374
name: False positive
def: "An instance where a prediction or test incorrectly identifies the presence of a condition or feature when it is actually absent. False positives represent incorrect positive predictions and affect specificity metrics." []
comment: Definition source - Claude 4.5 Sonnet through Claude Code in VSCode (Dec 16 2025)
xref: COMO:0000165
is_a: bervo:BERVO_8000232 ! Concept
property_value: bervo:BERVO_Attribute http://www.w3.org/2002/07/NA
